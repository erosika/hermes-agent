#!/usr/bin/env python3
"""
Charizard Agent CLI Launcher

This is a convenience wrapper to launch the Hermes CLI in Charizard skin mode.
Usage: ./charizard [options]
"""

if __name__ == "__main__":
    import os

    os.environ["HERMES_CLI_SKIN"] = "charizard"
    from cli import main
    import fire

    fire.Fire(main)
